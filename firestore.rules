rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helper
    function isAuth() {
      return request.auth != null;
    }

    // Admin Helper — checks role from Firestore users collection
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Finance Helper — checks if user is admin OR has explicit finance access
    function canAccessFinance() {
      return isAuth() && (
        isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canAccessFinance == true
      );
    }
    
    // 1. Users Collection — read: any authenticated, write: admin only
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // 2. RMAs Collection
    match /rmas/{rmaId} {
      // Public: read a single document by ID (for customer tracking page)
      // ลูกค้าสามารถดูสถานะเคลมได้โดยไม่ต้อง login
      allow get: if true;
      
      // List: authenticated staff only, OR limited public queries (max 5 results)
      // ลูกค้าค้นหาด้วย S/N, เลข Ref, หรือ Group ID ได้ (จำกัด 5 ผลลัพธ์)
      allow list: if isAuth() || request.query.limit <= 5;
      
      // Update: authenticated staff only
      allow update: if isAuth();

      // Delete: ADMIN ONLY — ข้อมูลห้ามหาย ต้องเป็น admin เท่านั้นถึงลบได้
      allow delete: if isAdmin();
      
      // Creation: Staff OR public guest submit (with strict restrictions)
      // ลูกค้าสามารถลงทะเบียนเคลมได้โดยไม่ต้อง login
      allow create: if isAuth() || (
        request.resource.data.status == 'PENDING' &&
        request.resource.data.createdBy == 'Customer (Web)' &&
        // Prevent guest from setting admin-only fields
        !('serviceType' in request.resource.data) &&
        !('resolution' in request.resource.data) &&
        !('repairCosts' in request.resource.data) &&
        // Schema Validation for guest creations
        request.resource.data.customerName is string && request.resource.data.customerName.size() > 0 &&
        request.resource.data.contactPerson is string && request.resource.data.contactPerson.size() > 0 &&
        request.resource.data.customerPhone is string && request.resource.data.customerPhone.size() > 0 &&
        request.resource.data.customerAddress is string && request.resource.data.customerAddress.size() > 0 &&
        request.resource.data.lineAccount is string && request.resource.data.lineAccount.size() > 0 &&
        request.resource.data.brand is string && request.resource.data.brand.size() > 0 &&
        request.resource.data.productModel is string && request.resource.data.productModel.size() > 0 &&
        request.resource.data.serialNumber is string && request.resource.data.serialNumber.size() > 0 &&
        request.resource.data.issueDescription is string && request.resource.data.issueDescription.size() > 0
      );
    }
    
    // 3. Config/Master Data — public read, admin write
    match /brands/{d} { allow read: if true; allow write: if isAdmin(); }
    match /distributors/{d} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{d} { allow read: if true; allow write: if isAdmin(); }
    
    // 4. Counters — public read (ลูกค้าต้องอ่าน counter เพื่อสร้าง Job ID ตอนลงทะเบียน)
    // Write: authenticated staff only — ป้องกันคนนอกมาแก้ counter
    match /counters/{d} { allow read: if true; allow write: if isAuth(); }

    // 5. Mail Collection (for Firebase Trigger Email Extension)
    match /mail/{mailId} {
      allow create: if isAuth();
    }

    // 6. Petty Cash Collection — staff with finance access, admin delete
    match /pettycash/{txId} {
      allow read: if canAccessFinance();
      allow create: if canAccessFinance();
      allow update: if canAccessFinance() && (
        // Soft delete: setting isDeleted to true requires Admin role
        (request.resource.data.get('isDeleted', false) == resource.data.get('isDeleted', false) || isAdmin()) &&
        // Prevent editing already reimbursed transactions unless Admin
        (resource.data.get('isReimbursed', false) == false || isAdmin())
      );
      allow delete: if isAdmin();
    }
  }
}
