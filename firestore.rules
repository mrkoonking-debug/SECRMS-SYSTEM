rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helper
    function isAuth() {
      return request.auth != null;
    }

    // Admin Helper — checks role from Firestore users collection
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // 1. Users Collection — read: any authenticated, write: admin only
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // 2. RMAs Collection
    match /rmas/{rmaId} {
      // Public: read a single document by ID (for customer tracking page)
      // ลูกค้าสามารถดูสถานะเคลมได้โดยไม่ต้อง login
      allow get: if true;
      
      // List: authenticated staff only, OR limited public queries (max 5 results)
      // ลูกค้าค้นหาด้วย S/N, เลข Ref, หรือ Group ID ได้ (จำกัด 5 ผลลัพธ์)
      allow list: if isAuth() || request.query.limit <= 5;
      
      // Update: authenticated staff only
      allow update: if isAuth();

      // Delete: ADMIN ONLY — ข้อมูลห้ามหาย ต้องเป็น admin เท่านั้นถึงลบได้
      allow delete: if isAdmin();
      
      // Creation: Staff OR public guest submit (with strict restrictions)
      // ลูกค้าสามารถลงทะเบียนเคลมได้โดยไม่ต้อง login
      allow create: if isAuth() || (
        request.resource.data.status == 'PENDING' &&
        request.resource.data.createdBy == 'Customer (Web)' &&
        // Prevent guest from setting admin-only fields
        !('serviceType' in request.resource.data) &&
        !('resolution' in request.resource.data) &&
        !('repairCosts' in request.resource.data)
      );
    }
    
    // 3. Config/Master Data — public read, admin write
    match /brands/{d} { allow read: if true; allow write: if isAdmin(); }
    match /distributors/{d} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{d} { allow read: if true; allow write: if isAdmin(); }
    
    // 4. Counters — public read (ลูกค้าต้องอ่าน counter เพื่อสร้าง Job ID ตอนลงทะเบียน)
    // Write: authenticated staff only — ป้องกันคนนอกมาแก้ counter
    match /counters/{d} { allow read: if true; allow write: if isAuth(); }

    // 5. Mail Collection (for Firebase Trigger Email Extension)
    match /mail/{mailId} {
      allow create: if isAuth();
    }

    // 6. Petty Cash Collection — staff read/write, admin delete
    match /pettycash/{txId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }
  }
}
